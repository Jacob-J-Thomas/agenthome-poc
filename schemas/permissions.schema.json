{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentHome permissions v0",
  "type": "object",
  "required": ["version", "defaultDecision", "rules"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "defaultDecision": { "enum": ["Allow", "Prompt", "Deny"] },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "target", "decision"],
        "properties": {
          "action": { "type": "string" },
          "target": { "type": "string" },
          "decision": { "enum": ["Allow", "Prompt", "Deny"] },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
