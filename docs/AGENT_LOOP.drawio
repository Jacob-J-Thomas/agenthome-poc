        <mxCell id="title" value="EmbodySense current implementation: default conversation loop" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="30" width="760" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="This page documents ordinary chat. The separate Custom Loop MVP page documents Web authoring and custom execution. Source of truth: src/EmbodySense.Cli, src/EmbodySense.Web, and src/EmbodySense.Core." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontColor=#4A5568" vertex="1" parent="1">
          <mxGeometry x="60" y="72" width="1020" height="34" as="geometry" />
        </mxCell>
        <mxCell id="program" value="CLI Program.RunAsync(args)&lt;br&gt;Web WebAgentRuntimeHost&lt;br&gt;Surface host enters shared runtime facade" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F2FF;strokeColor=#2B6CB0;fontSize=13" vertex="1" parent="1">
