          <mxGeometry x="1040" y="1070" width="205" height="80" as="geometry" />
        </mxCell>
        <mxCell id="codex" value="CodexAppServerInferenceClient&lt;br&gt;ContextBuilder builds turn input + assigned command guidance&lt;br&gt;ToolBridge exposes loop-assigned dynamic commands" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8FF;strokeColor=#3182CE;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="1240" y="1185" width="285" height="85" as="geometry" />
        </mxCell>
        <mxCell id="process" value="Start Codex app-server process&lt;br&gt;codex[.cmd] app-server --stdio&lt;br&gt;Send JSON-RPC thread/start + turn/start&lt;br&gt;Read item/agentMessage/delta + turn/completed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8FF;strokeColor=#3182CE;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="1240" y="1310" width="285" height="125" as="geometry" />
        </mxCell>
        <mxCell id="exitCode" value="turn/completed status?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF7E6;strokeColor=#B7791F;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="1265" y="1475" width="170" height="95" as="geometry" />
        </mxCell>
        <mxCell id="failure" value="Failure path&lt;br&gt;Record failed/cancelled loop run&lt;br&gt;Return AgentRuntimeTurnResult failure/cancelled&lt;br&gt;Surface projects error/cancel event" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF5F5;strokeColor=#C53030;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="960" y="1470" width="250" height="115" as="geometry" />
        </mxCell>
        <mxCell id="success" value="Success path&lt;br&gt;Extract final agentMessage from turn/completed&lt;br&gt;Return LlmInferenceResponse&lt;br&gt;Append llm.inference.complete succeeded if audit log exists" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FFF4;strokeColor=#2F855A;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="1240" y="1610" width="285" height="95" as="geometry" />
        </mxCell>
        <mxCell id="print" value="DefaultConversationLoopRunner stores assistant output while lease remains held&lt;br&gt;Record completed loop run or surface terminal persistence failure&lt;br&gt;Release workspace conversation lease&lt;br&gt;Console/Web projects output; prompt again" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FFF4;strokeColor=#2F855A;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="930" y="1630" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="boundaries" value="Current boundaries&lt;br&gt;- Default conversation turns flow through DefaultConversationLoopRunner.&lt;br&gt;- One file-backed workspace conversation lease serializes default turns across runtime instances and processes from durable transcript synchronization through inference and assistant state + memory persistence.&lt;br&gt;- Default loop definition is loaded from .agent/loops/definitions when present.&lt;br&gt;- Current definition shape requires an explicit system-locked graph and validated edge chain.&lt;br&gt;- Loop run records are written for started/completed/failed/cancelled turns.&lt;br&gt;- Terminal completed-run persistence failure surfaces as a failed turn.&lt;br&gt;- Loop CapabilityIds filter workspace commands before permissions.&lt;br&gt;- ToolPermissionService + ToolBroker enforce path policy, approval, execution, and audit.&lt;br&gt;- Verbose mode shows logical pre-provider context, graph summary, loop authority, memory status, limits, and compaction status.&lt;br&gt;- Web and CLI turns share AgentRuntime.RunTurnAsync." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7FAFC;strokeColor=#718096;fontSize=12;dashed=1" vertex="1" parent="1">
          <mxGeometry x="70" y="870" width="520" height="205" as="geometry" />
        </mxCell>
        <mxCell id="maintenance" value="Documentation maintenance&lt;br&gt;Agents should update README.md and this draw.io source in the same change when real implementation behavior changes." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFAF0;strokeColor=#C05621;fontSize=12;dashed=1" vertex="1" parent="1">
