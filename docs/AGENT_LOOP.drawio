        <mxCell id="ce8" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2C7A7B;endArrow=block;endFill=1" edge="1" parent="c1" source="c-gate" target="c-capture"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2C7A7B;endArrow=block;endFill=1" edge="1" parent="c1" source="c-capture" target="c-admit"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6B46C1;endArrow=block;endFill=1" edge="1" parent="c1" source="c-admit" target="c-running"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6B46C1;endArrow=block;endFill=1" edge="1" parent="c1" source="c-running" target="c-next-step"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1665" y="620" /><mxPoint x="170" y="620" /></Array></mxGeometry></mxCell>
        <mxCell id="ce12" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#3182CE;endArrow=block;endFill=1" edge="1" parent="c1" source="c-next-step" target="c-context"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#3182CE;endArrow=block;endFill=1" edge="1" parent="c1" source="c-context" target="c-started"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#3182CE;endArrow=block;endFill=1" edge="1" parent="c1" source="c-started" target="c-provider"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2F855A;endArrow=block;endFill=1" edge="1" parent="c1" source="c-provider" target="c-outcome"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2F855A;endArrow=block;endFill=1" edge="1" parent="c1" source="c-outcome" target="c-checkpoint"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce17" value="next boundary" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2C7A7B;endArrow=block;endFill=1" edge="1" parent="c1" source="c-checkpoint" target="c-next-step"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1530" y="915" /><mxPoint x="1530" y="840" /><mxPoint x="170" y="840" /></Array></mxGeometry></mxCell>
        <mxCell id="ce18" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#B7791F;endArrow=block;endFill=1" edge="1" parent="c1" source="c-next-step" target="c-exit-gate"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce19" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2F855A;endArrow=block;endFill=1" edge="1" parent="c1" source="c-exit-gate" target="c-deterministic-exit"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce20" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#3182CE;endArrow=block;endFill=1" edge="1" parent="c1" source="c-exit-gate" target="c-exit-call"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce21" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#3182CE;endArrow=block;endFill=1" edge="1" parent="c1" source="c-exit-call" target="c-exit-decision"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce22" value="Complete" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2F855A;endArrow=block;endFill=1" edge="1" parent="c1" source="c-exit-decision" target="c-exit-complete"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce23" value="Repeat" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#B7791F;endArrow=block;endFill=1" edge="1" parent="c1" source="c-exit-decision" target="c-repeat"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce24" value="invalid / uncertain" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#C53030;endArrow=block;endFill=1" edge="1" parent="c1" source="c-exit-decision" target="c-needs-review"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce25" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2F855A;endArrow=block;endFill=1" edge="1" parent="c1" source="c-deterministic-exit" target="c-terminal"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="200" y="1210" /><mxPoint x="1705" y="1210" /></Array></mxGeometry></mxCell>
        <mxCell id="ce26" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2F855A;endArrow=block;endFill=1" edge="1" parent="c1" source="c-exit-complete" target="c-terminal"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce27" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#C53030;endArrow=block;endFill=1" edge="1" parent="c1" source="c-needs-review" target="c-terminal"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce28" value="restart at Step 1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#B7791F;endArrow=block;endFill=1" edge="1" parent="c1" source="c-repeat" target="c-next-step"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1255" y="1195" /><mxPoint x="380" y="1195" /><mxPoint x="380" y="740" /></Array></mxGeometry></mxCell>
        <mxCell id="ce29" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;strokeColor=#6B46C1;endArrow=block;endFill=1" edge="1" parent="c1" source="c-running" target="c-lifecycle"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce30" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;strokeColor=#B7791F;endArrow=block;endFill=1" edge="1" parent="c1" source="c-provider" target="c-approvals"><mxGeometry relative="1" as="geometry" /></mxCell>
