        </mxCell>
        <mxCell id="init" value="init [root]&lt;br&gt;WorkspaceInitializer.InitializeAsync(root)&lt;br&gt;WorkspaceDefaults supplies dirs and seed files&lt;br&gt;Append workspace.init audit event" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFFA;strokeColor=#2C7A7B;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="350" y="235" width="270" height="115" as="geometry" />
        </mxCell>
        <mxCell id="status" value="status [root]&lt;br&gt;WorkspacePaths + ToolPermissionService&lt;br&gt;Print initialized state, audit path,&lt;br&gt;permissions defaults, read/write dirs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFFA;strokeColor=#2C7A7B;fontSize=12" vertex="1" parent="1">
