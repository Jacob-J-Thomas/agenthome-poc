        <mxCell id="ce32" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;strokeColor=#2B6CB0;endArrow=block;endFill=1" edge="1" parent="c1" source="c-terminal" target="c-inspection"><mxGeometry relative="1" as="geometry" /></mxCell>
