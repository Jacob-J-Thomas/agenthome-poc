  <diagram id="embodysense-agent-loop" name="Current Agent Loop">
    <mxGraphModel dx="1896" dy="1214" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
