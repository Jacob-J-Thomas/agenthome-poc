        </mxCell>
        <mxCell id="addUser" value="DefaultConversationLoopRunner.RunTurnAsync(input)&lt;br&gt;Acquire cross-process, workspace-scoped conversation lease before context assembly&lt;br&gt;Synchronize runtime transcript from durable current conversation&lt;br&gt;Create + validate run, append user state + memory&lt;br&gt;Hold lease across inference and assistant state + memory persistence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8FF;strokeColor=#3182CE;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="930" y="920" width="245" height="90" as="geometry" />
        </mxCell>
        <mxCell id="generate" value="LlmInferenceClient.GenerateAsync(request)&lt;br&gt;Delegates through audited provider pipeline&lt;br&gt;Append llm.inference.start if .agent exists" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8FF;strokeColor=#3182CE;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="1240" y="920" width="285" height="95" as="geometry" />
        </mxCell>
        <mxCell id="surface" value="Internal provider factory&lt;br&gt;Surface switch" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF7E6;strokeColor=#B7791F;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="1268" y="1055" width="145" height="90" as="geometry" />
        </mxCell>
